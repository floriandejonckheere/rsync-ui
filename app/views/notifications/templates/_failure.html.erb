<div
  style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; background: #f9f9f9; padding: 20px; border-radius: 8px; border: 1px solid #e0e0e0;"
>
  <div
    style="background: #ef4444; color: white; padding: 20px; border-radius: 8px; margin: -20px -20px 24px -20px; text-align: center;"
  >
    <h1 style="margin: 0; font-size: 24px; font-weight: bold;">
      <%= t("notifications.templates.header_failure") %>
    </h1>
  </div>

  <div style="margin-bottom: 20px;">
    <h2
      style="margin: 0 0 8px 0; color: #333; font-size: 18px; font-weight: 600;"
    >
      <%= job_run.job.name %>
    </h2>

    <p style="margin: 0 0 8px 0; color: #999; font-size: 13px;">
      Run #<%= job_run.sequence %>
    </p>

    <p style="margin: 0; color: #666; font-size: 14px;">
      Failed at <%= l(job_run.completed_at, format: :long) %>
    </p>
  </div>

  <div
    style="background: white; padding: 16px; border-radius: 6px; border: 1px solid #e0e0e0; margin-bottom: 16px;"
  >
    <div style="margin-bottom: 12px;">
      <span style="color: #666; font-size: 13px; font-weight: 500;">
        <%= t("notifications.templates.source") %>:
      </span>

      <span style="color: #333; font-size: 14px; margin-left: 8px;">
        <%= job_run.job.source_repository.name %>
      </span>
    </div>

    <div style="margin-bottom: 12px;">
      <span style="color: #666; font-size: 13px; font-weight: 500;">
        <%= t("notifications.templates.destination") %>:
      </span>

      <span style="color: #333; font-size: 14px; margin-left: 8px;">
        <%= job_run.job.destination_repository.name %>
      </span>
    </div>

    <div
      style="padding-top: 12px; border-top: 1px solid #e0e0e0; margin-top: 12px;"
    >
      <% if job_run.error_class.present? %>
        <div style="margin-bottom: 8px;">
          <span style="color: #666; font-size: 13px; font-weight: 500;">
            <%= t("notifications.templates.error_type") %>:
          </span>

          <span
            style="color: #d32f2f; font-size: 14px; margin-left: 8px; font-family: 'Monaco', 'Courier New', monospace;"
          >
            <%= job_run.error_class %>
          </span>
        </div>
      <% end %>

      <% if job_run.error_messages.present? %>
        <div
          style="margin-top: 8px; padding: 8px; background: #fef2f2; border-left: 3px solid #ef4444; border-radius: 4px;"
        >
          <span
            style="color: #666; font-size: 13px; font-weight: 500; display: block; margin-bottom: 4px;"
          >
            <%= t("notifications.templates.error_details") %>:
          </span>

          <p
            style="margin: 0; color: #333; font-size: 13px; font-family: 'Monaco', 'Courier New', monospace; word-break: break-word; white-space: pre-wrap;"
          >
            <%= job_run.error_messages %>
          </p>
        </div>
      <% end %>

      <div style="margin-top: 12px;">
        <span style="color: #666; font-size: 13px; font-weight: 500;">
          <%= t("notifications.templates.duration") %>:
        </span>

        <span style="color: #333; font-size: 14px; margin-left: 8px;">
          <%= distance_of_time_in_words(job_run.started_at, job_run.completed_at) %>
        </span>
      </div>
    </div>
  </div>

  <div style="text-align: center; margin-bottom: 16px;">
    <a
      href="<%= job_run_url(job_run) %>"
      style="display: inline-block; padding: 10px 20px; background: #ef4444; color: white; text-decoration: none; border-radius: 6px; font-size: 14px; font-weight: 500;"
    >
      <%= t("notifications.templates.view_logs") %>
    </a>
  </div>

  <div
    style="text-align: center; padding-top: 16px; border-top: 1px solid #e0e0e0; color: #999; font-size: 12px;"
  >
    <p style="margin: 0;">
      <%= t("notifications.templates.footer") %>
    </p>
  </div>
</div>

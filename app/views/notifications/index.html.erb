<% content_for :title do %>
  <%= I18n.t("notifications.index.title") %>
<% end %>

<% content_for :subtitle do %>
  <%= I18n.t("notifications.index.subtitle") %>
<% end %>

<% content_for :actions do %>
  <%= render "shared/search/search",
             url: notifications_path,
             query: @query,
             frame: "notifications_list",
             placeholder: I18n.t("notifications.index.search.placeholder") %>

  <%= link_to new_notification_path, data: { tooltip: I18n.t("notifications.index.new") }, class: "btn-icon-outline btn-icon-lg" do %>
    <%= lucide_icon "plus", class: "h-6 w-6" %>
  <% end %>
<% end %>

<%= turbo_frame_tag "notifications_list" do %>
  <% if @notifications.empty? && @query.present? %>
    <%= render "shared/search/no_results", title: I18n.t("notifications.index.search.no_results.title") %>
  <% elsif @notifications.empty? %>
    <div
      class="
        card flex flex-col items-center justify-center py-16 gap-4
        text-gray-400
      "
    >
      <%= lucide_icon "bell", class: "h-12 w-12" %>

      <p class="text-lg">
        <%= I18n.t("notifications.index.empty") %>
      </p>
    </div>
  <% else %>
    <div class="card p-0">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 dark:border-gray-700">
            <th class="py-4 w-10"></th>

            <%= render "shared/sort_header", column: "name", label: I18n.t("notifications.table.name") %>

            <th
              class="
                px-6 py-4 text-left font-medium text-gray-500
                dark:text-gray-400
              "
            >
              <%= I18n.t("notifications.table.description") %>
            </th>

            <th class="px-6 py-4"></th>
          </tr>
        </thead>

        <tbody>
          <% @notifications.each do |notification| %>
            <%= render "notification", notification: %>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @pagy.pages > 1 %>
      <%= render "shared/pagination", pagy: @pagy, path_method: :notifications_path %>
    <% end %>
  <% end %>
<% end %>

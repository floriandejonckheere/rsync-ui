<div class="card">
  <header>
    <h2 class="text-2xl font-bold"><%= I18n.t("application.name") %></h2>
  </header>

  <% if devise_mapping.try(:omniauthable?) %>
    <section>
      <%- resource_class.omniauth_providers.each do |provider| %>
        <%= button_to omniauth_authorize_path(resource_name, provider), method: :post, data: { turbo: false }, class: "btn-outline w-full" do %>
          <% if provider == :google_oauth2 %>
            <%= image_tag "google.svg", class: "size-5" %>
          <% end %>

          <%= I18n.t("devise.sessions.sign_in_with_provider", provider: provider.to_s.sub("_oauth2", "").titleize) %>
        <% end %>
      <% end %>

      <div class="relative my-4 mt-8">
        <div class="absolute inset-0 flex items-center">
          <span class="w-full border-t"></span>
        </div>

        <div class="relative flex justify-center text-xs uppercase">
          <span class="bg-card px-2 text-muted-foreground">
            <%= I18n.t("devise.sessions.or") %>
          </span>
        </div>
      </div>
    </section>
  <% end %>

  <section>
    <%= form_for resource, as: resource_name, url: session_path(resource_name), html: { class: "form" } do |f| %>
      <%= render "devise/shared/error_messages", resource: %>

      <div class="flex flex-col gap-8">
        <div class="field">
          <%= f.label :email %>
          <%= f.email_field :email, required: true, autofocus: true, autocomplete: "email" %>
        </div>

        <div class="field">
          <%= f.label :password %>
          <%= f.password_field :password, required: true, autocomplete: "current-password" %>

          <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <p>
              <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-primary hover:underline text-sm" %>
            </p>
          <% end %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me %>
          </div>
        <% end %>

        <div class="flex justify-end mt-2">
          <%= f.submit I18n.t("devise.sessions.sign_in"), class: "btn-primary w-full" %>
        </div>
      </div>
    <% end %>
  </section>
</div>

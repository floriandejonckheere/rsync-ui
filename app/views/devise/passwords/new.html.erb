<div class="card">
  <header>
    <h2 class="text-2xl font-bold"><%= I18n.t("application.name") %></h2>

    <p>
      <%= I18n.t("devise.passwords.remembered_question") %>
      <%= link_to I18n.t("devise.sessions.sign_in"), new_user_session_path, class: "text-primary hover:underline" %>
    </p>
  </header>

  <section>
    <%= form_for resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "form" } do |f| %>
      <%= render "devise/shared/error_messages" %>

      <div class="flex flex-col gap-8">
        <div class="field">
          <%= f.label :email %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
        </div>

        <div class="flex justify-end mt-2">
          <%= f.submit I18n.t("devise.passwords.send_reset_password_instructions"), class: "btn-primary w-full" %>
        </div>
      </div>
    <% end %>
  </section>
</div>

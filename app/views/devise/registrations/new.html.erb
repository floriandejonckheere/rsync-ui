<div class="card">
  <header>
    <h2 class="text-2xl font-bold"><%= I18n.t("application.name") %></h2>

    <p>
      <%= I18n.t("devise.sessions.already_account") %>

      <%= link_to I18n.t("devise.sessions.sign_in"), new_user_session_path, class: "text-primary hover:underline" %>
    </p>
  </header>

  <section>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "form" }) do |f| %>
      <div class="flex flex-col gap-8">
        <div class="field">
          <div class="flex flex-row gap-1">
            <%= f.label :email %>
            <span class="text-destructive">*</span>
          </div>

          <%= f.email_field :email, required: true, autofocus: true, autocomplete: "email" %>
        </div>

        <div class="field">
          <div class="flex flex-row gap-1">
            <%= f.label :first_name %>
            <span class="text-destructive">*</span>
          </div>

          <%= f.text_field :first_name, required: true %>
        </div>

        <div class="field">
          <div class="flex flex-row gap-1">
            <%= f.label :last_name %>
            <span class="text-destructive">*</span>
          </div>

          <%= f.text_field :last_name, required: true %>
        </div>

        <div class="field">
          <div class="flex items-center gap-2">
            <div class="flex flex-row gap-1">
              <%= f.label :password, required: true %>
              <span class="text-destructive">*</span>
            </div>

            <% if @minimum_password_length %>
              <span class="text-xs text-muted-foreground">
                (<%= I18n.t("devise.registrations.minimum_password_length", length: @minimum_password_length) %>)
              </span>
            <% end %>
          </div>

          <%= f.password_field :password %>
        </div>

        <div class="field">
          <div class="flex flex-row gap-1">
            <%= f.label :password_confirmation %>
            <span class="text-destructive">*</span>
          </div>

          <%= f.password_field :password_confirmation, required: true %>
        </div>

        <div class="flex justify-end mt-2">
          <%= f.submit I18n.t("devise.sessions.sign_up"), class: "btn-primary w-full" %>
        </div>
      </div>
    <% end %>
  </section>
</div>

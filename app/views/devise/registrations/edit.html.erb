<%= content_for :title do %>
  <%= I18n.t("settings.title") %>
<% end %>

<%= content_for :subtitle do %>
  <%= I18n.t("settings.subtitle") %>
<% end %>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { id: "account-form", class: "form" }) do |f| %>
  <% content_for :actions do %>
    <button
      type="submit"
      form="account-form"
      class="btn-icon-outline btn-icon-lg"
      data-tooltip="<%= I18n.t("settings.update") %>"
    >
      <%= lucide_icon "check", class: "h-6 w-6" %>
    </button>
  <% end %>

  <% if current_user.errors.any? %>
    <div class="mb-8">
      <%= render "shared/forms/messages", model: current_user %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-8">
    <div class="card">
      <header>
        <h2><%= I18n.t("settings.account.title") %></h2>
      </header>

      <section>
        <div class="flex flex-col gap-6">
          <div class="field">
            <%= f.label :first_name, I18n.t("settings.account.first_name") %>

            <%= f.text_field :first_name,
                             placeholder: I18n.t("settings.account.first_name_placeholder"),
                             required: true,
                             autocomplete: "off" %>
          </div>

          <div class="field">
            <%= f.label :last_name, I18n.t("settings.account.last_name") %>

            <%= f.text_field :last_name,
                             placeholder: I18n.t("settings.account.last_name_placeholder"),
                             required: true,
                             autocomplete: "off" %>
          </div>

          <div class="field">
            <%= f.label :email, I18n.t("settings.account.email") %>

            <%= f.text_field :email,
                             placeholder: I18n.t("settings.account.email_placeholder"),
                             required: true,
                             autocomplete: "off" %>
          </div>
        </div>
      </section>
    </div>

    <div class="card">
      <header>
        <h2><%= I18n.t("settings.password.title") %></h2>
      </header>

      <section>
        <div class="flex flex-col gap-6">
          <div class="field">
            <%= f.label :password, I18n.t("settings.password.password") %>

            <%= f.password_field :password,
                                 placeholder: I18n.t("settings.password.password_placeholder"),
                                 autocomplete: "new-password" %>
          </div>

          <div class="field">
            <%= f.label :password_confirmation, I18n.t("settings.password.confirmation") %>

            <%= f.password_field :password_confirmation,
                                 placeholder: I18n.t("settings.password.confirmation_placeholder"),
                                 autocomplete: "new-password" %>
          </div>
        </div>
      </section>
    </div>
  </div>
<% end %>

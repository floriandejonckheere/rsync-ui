<%= form_with model: job, id: "job-form", class: "form",
              data: {
                controller: "unsaved-changes command-preview",
                "command-preview-url-value": preview_jobs_path,
              } do |f| %>
  <% content_for :actions do %>
    <button
      type="submit"
      form="job-form"
      class="btn-icon-outline btn-icon-lg"
      data-tooltip="<%= job.persisted? ? I18n.t("jobs.form.submit_update") : I18n.t("jobs.form.submit_create") %>"
    >
      <%= lucide_icon "check", class: "h-6 w-6" %>
    </button>
  <% end %>

  <% if job.errors.any? %>
    <div class="mb-8">
      <%= render "shared/forms/messages", model: job %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-8 items-start">
    <div class="flex flex-col gap-8">
      <div class="card">
        <header>
          <h2><%= I18n.t("jobs.form.details") %></h2>
        </header>

        <section>
          <div class="flex flex-col gap-6">
            <div class="field">
              <%= f.label :name, I18n.t("jobs.form.name") %>

              <%= f.text_field :name,
                               placeholder: I18n.t("jobs.form.name_placeholder"),
                               required: true,
                               autocomplete: "off" %>
            </div>

            <div class="field">
              <%= f.label :description, I18n.t("jobs.form.description") %>

              <%= f.text_area :description,
                              placeholder: I18n.t("jobs.form.description_placeholder"),
                              rows: 3,
                              autocomplete: "off" %>
            </div>

            <div
              class="field"
              data-controller="cron-preview"
              data-cron-preview-placeholder-value="<%= I18n.t("jobs.form.schedule_preview_placeholder") %>"
              data-cron-preview-invalid-value="<%= I18n.t("jobs.form.schedule_preview_invalid") %>"
            >
              <%= f.label :schedule, I18n.t("jobs.form.schedule") %>

              <%= f.text_field :schedule,
                               placeholder: I18n.t("jobs.form.schedule_placeholder"),
                               autocomplete: "off",
                               data: { cron_preview_target: "input", action: "input->cron-preview#update" } %>

              <span
                class="text-muted-foreground mt-1 text-sm"
                data-cron-preview-target="output"
              ></span>
            </div>

            <div class="field flex-row items-center gap-4">
              <%= f.check_box :enabled, role: "switch" %>

              <%= f.label :enabled, I18n.t("jobs.form.enabled") %>
            </div>
          </div>
        </section>
      </div>

      <div class="card">
        <header>
          <h2><%= I18n.t("jobs.form.repositories") %></h2>
        </header>

        <section>
          <div class="flex flex-col gap-6">
            <div class="field">
              <%= f.label :source_repository_id, I18n.t("jobs.form.source_repository") %>

              <%= render "shared/forms/combobox",
                         name: f.field_name(:source_repository_id),
                         value: job.source_repository_id,
                         options: @repositories.map { |repository| [repository.name, repository.id] },
                         blank_label: I18n.t("jobs.form.source_repository_placeholder"),
                         placeholder: I18n.t("jobs.form.source_repository_search_placeholder"),
                         required: true %>
            </div>

            <div class="field">
              <%= f.label :destination_repository_id, I18n.t("jobs.form.destination_repository") %>

              <%= render "shared/forms/combobox",
                         name: f.field_name(:destination_repository_id),
                         value: job.destination_repository_id,
                         options: @repositories.map { |repository| [repository.name, repository.id] },
                         blank_label: I18n.t("jobs.form.destination_repository_placeholder"),
                         placeholder: I18n.t("jobs.form.destination_repository_search_placeholder"),
                         required: true %>
            </div>
          </div>
        </section>
      </div>

      <% if Configuration.get("notifications") %>
        <div class="card">
          <header>
            <h2><%= I18n.t("jobs.form.notifications") %></h2>
          </header>

          <section>
            <% available = current_user.notifications.where(enabled: true).order(:name) %>

            <% if available.empty? %>
              <p class="text-sm text-muted-foreground">
                <%= I18n.t("jobs.form.notifications_empty_html",
                           link: link_to(I18n.t("jobs.form.notifications_empty_link"), notifications_path)).html_safe %>
              </p>
            <% else %>
              <div class="flex flex-col gap-6">
                <% available.each do |notif| %>
                  <% existing = job.job_notifications.find { |jn| jn.notification_id == notif.id } %>
                  <% jn = existing || job.job_notifications.build(notification: notif, enabled: false) %>

                  <%= f.fields_for :job_notifications, jn do |jnf| %>
                    <%= jnf.hidden_field :notification_id %>

                    <% if jn.persisted? %>
                      <%= jnf.hidden_field :id %>
                    <% end %>

                    <div class="border rounded p-4 relative">
                      <div class="absolute top-4 right-4">
                        <div class="field flex-row items-center gap-4">
                          <%= jnf.check_box :enabled, role: "switch" %>
                        </div>
                      </div>

                      <div class="mb-4 pr-16">
                        <h3 class="font-semibold text-base">
                          <%= notif.name %>
                        </h3>

                        <p class="text-sm text-muted-foreground mt-1">
                          <%= notif.description %>
                        </p>
                      </div>

                      <div class="flex flex-row gap-6">
                        <div class="field flex-row items-center gap-4">
                          <%= jnf.check_box :on_start %>
                          <%= jnf.label :on_start, I18n.t("jobs.form.notifications_on_start") %>
                        </div>

                        <div class="field flex-row items-center gap-4">
                          <%= jnf.check_box :on_success %>
                          <%= jnf.label :on_success, I18n.t("jobs.form.notifications_on_success") %>
                        </div>

                        <div class="field flex-row items-center gap-4">
                          <%= jnf.check_box :on_failure %>
                          <%= jnf.label :on_failure, I18n.t("jobs.form.notifications_on_failure") %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </section>
        </div>
      <% end %>
    </div>

    <div class="flex flex-col gap-8">
      <details class="card group py-0" open>
        <summary
          class="
            flex items-center justify-between w-full px-8 py-8
            cursor-pointer list-none
          "
        >
          <h2 class="text-lg font-semibold">
            <%= I18n.t("jobs.form.preview") %>
          </h2>

          <%= lucide_icon "chevron-down", class: "h-5 w-5 transition-transform duration-200 group-open:rotate-180" %>
        </summary>

        <div class="px-8 pb-8">
          <%= render "preview" %>
        </div>
      </details>

      <details class="card group py-0">
        <summary
          class="
            flex items-center justify-between w-full px-8 py-8
            cursor-pointer list-none
          "
        >
          <h2 class="text-lg font-semibold">
            <%= I18n.t("jobs.form.include_exclude_patterns") %>
          </h2>

          <%= lucide_icon "chevron-down", class: "h-5 w-5 transition-transform duration-200 group-open:rotate-180" %>
        </summary>

        <div class="px-8 pb-8">
          <div class="grid grid-cols-2 gap-8">
            <div>
              <p class="font-medium mb-4">
                <%= I18n.t("jobs.form.include_patterns") %>
              </p>

              <div
                data-controller="pattern-list"
                data-pattern-list-field-name-value="job[opt_include][]"
                data-pattern-list-placeholder-value="<%= I18n.t("jobs.form.pattern_placeholder") %>"
              >
                <template data-pattern-list-target="template">
                  <div data-pattern-row class="flex gap-2 items-center mb-2">
                    <input type="text" class="flex-1" autocomplete="off">

                    <button
                      type="button"
                      class="btn-icon-outline"
                      data-action="pattern-list#remove"
                    >
                      <%= lucide_icon "trash-2", class: "h-4 w-4" %>
                    </button>
                  </div>
                </template>

                <input type="hidden" name="job[opt_include][]" value="">

                <div data-pattern-list-target="list">
                  <% job.opt_include.each do |pattern| %>
                    <div data-pattern-row class="flex gap-2 items-center mb-2">
                      <input
                        type="text"
                        name="job[opt_include][]"
                        value="<%= pattern %>"
                        placeholder="<%= I18n.t("jobs.form.pattern_placeholder") %>"
                        class="flex-1"
                        autocomplete="off"
                      >

                      <button
                        type="button"
                        class="btn-icon-outline"
                        data-action="pattern-list#remove"
                      >
                        <%= lucide_icon "trash-2", class: "h-4 w-4" %>
                      </button>
                    </div>
                  <% end %>
                </div>

                <button
                  type="button"
                  class="btn-outline mt-2"
                  data-action="pattern-list#add"
                >
                  <%= lucide_icon "plus", class: "h-4 w-4 mr-1 inline" %>
                  <%= I18n.t("jobs.form.add_pattern") %>
                </button>
              </div>
            </div>

            <div>
              <p class="font-medium mb-4">
                <%= I18n.t("jobs.form.exclude_patterns") %>
              </p>

              <div
                data-controller="pattern-list"
                data-pattern-list-field-name-value="job[opt_exclude][]"
                data-pattern-list-placeholder-value="<%= I18n.t("jobs.form.pattern_placeholder") %>"
              >
                <template data-pattern-list-target="template">
                  <div data-pattern-row class="flex gap-2 items-center mb-2">
                    <input type="text" class="flex-1" autocomplete="off">

                    <button
                      type="button"
                      class="btn-icon-outline"
                      data-action="pattern-list#remove"
                    >
                      <%= lucide_icon "trash-2", class: "h-4 w-4" %>
                    </button>
                  </div>
                </template>

                <input type="hidden" name="job[opt_exclude][]" value="">

                <div data-pattern-list-target="list">
                  <% job.opt_exclude.each do |pattern| %>
                    <div data-pattern-row class="flex gap-2 items-center mb-2">
                      <input
                        type="text"
                        name="job[opt_exclude][]"
                        value="<%= pattern %>"
                        placeholder="<%= I18n.t("jobs.form.pattern_placeholder") %>"
                        class="flex-1"
                        autocomplete="off"
                      >

                      <button
                        type="button"
                        class="btn-icon-outline"
                        data-action="pattern-list#remove"
                      >
                        <%= lucide_icon "trash-2", class: "h-4 w-4" %>
                      </button>
                    </div>
                  <% end %>
                </div>

                <button
                  type="button"
                  class="btn-outline mt-2"
                  data-action="pattern-list#add"
                >
                  <%= lucide_icon "plus", class: "h-4 w-4 mr-1 inline" %>
                  <%= I18n.t("jobs.form.add_pattern") %>
                </button>
              </div>
            </div>
          </div>
        </div>
      </details>

      <details class="card group py-0">
        <summary
          class="
            flex items-center justify-between w-full px-8 py-8
            cursor-pointer list-none
          "
        >
          <h2 class="text-lg font-semibold">
            <%= I18n.t("jobs.form.basic_options") %>
          </h2>

          <%= lucide_icon "chevron-down", class: "h-5 w-5 transition-transform duration-200 group-open:rotate-180" %>
        </summary>

        <div class="px-8 pb-8">
          <div class="flex flex-col gap-6">
            <% %i[opt_archive opt_recursive opt_relative opt_links opt_times opt_perms opt_owner opt_group opt_one_file_system opt_delete opt_delete_excluded opt_existing opt_ignore_existing opt_update opt_dry_run opt_inplace opt_size_only opt_progress].each do |field| %>
              <div class="field flex-row items-center gap-4">
                <%= f.check_box field, role: "switch" %>
                <%= f.label field, I18n.t(:description, scope: [:jobs, :form, field]), data: { tooltip: I18n.t(:flag, scope: [:jobs, :form, field]) } %>
              </div>
            <% end %>
          </div>
        </div>
      </details>

      <details class="card group py-0">
        <summary
          class="
            flex items-center justify-between w-full px-8 py-8
            cursor-pointer list-none
          "
        >
          <h2 class="text-lg font-semibold">
            <%= I18n.t("jobs.form.advanced_options") %>
          </h2>

          <%= lucide_icon "chevron-down", class: "h-5 w-5 transition-transform duration-200 group-open:rotate-180" %>
        </summary>

        <div class="px-8 pb-8">
          <div class="flex flex-col gap-6">
            <% %i[opt_acls opt_xattrs opt_hard_links opt_devices opt_specials opt_checksum opt_compress opt_partial opt_backup opt_append opt_numeric_ids opt_itemize_changes opt_secluded_args opt_verbose].each do |field| %>
              <div class="field flex-row items-center gap-4">
                <%= f.check_box field, role: "switch" %>
                <%= f.label field, I18n.t(:description, scope: [:jobs, :form, field]), data: { tooltip: I18n.t(:flag, scope: [:jobs, :form, field]) } %>
              </div>
            <% end %>
          </div>
        </div>
      </details>

      <details class="card group py-0">
        <summary
          class="
            flex items-center justify-between w-full px-8 py-8
            cursor-pointer list-none
          "
        >
          <h2 class="text-lg font-semibold">
            <%= I18n.t("jobs.form.custom_options") %>
          </h2>

          <%= lucide_icon "chevron-down", class: "h-5 w-5 transition-transform duration-200 group-open:rotate-180" %>
        </summary>

        <div class="px-8 pb-8">
          <div class="flex flex-col gap-6">
            <div class="field flex-row items-center gap-4">
              <%= f.check_box :opt_superuser, role: "switch" %>
              <%= f.label :opt_superuser, I18n.t("jobs.form.opt_superuser.description") %>
            </div>

            <div class="field">
              <%= f.label :opt_arguments, I18n.t("jobs.form.opt_arguments.description") %>

              <%= f.text_area :opt_arguments,
                              placeholder: I18n.t("jobs.form.opt_arguments.placeholder"),
                              rows: 3,
                              autocomplete: "off" %>
            </div>

            <div class="field">
              <%= f.label :opt_rsync_path, I18n.t("jobs.form.opt_rsync_path.description") %>

              <%= f.text_field :opt_rsync_path,
                               placeholder: I18n.t("jobs.form.opt_rsync_path.placeholder"),
                               autocomplete: "off" %>
            </div>
          </div>
        </div>
      </details>
    </div>
  </div>
<% end %>

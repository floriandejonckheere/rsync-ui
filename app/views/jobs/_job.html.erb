<tr
  class="
    border-b border-gray-100 dark:border-gray-700 last:border-b-0
    hover:bg-gray-50 dark:hover:bg-gray-700/50
    <%= "opacity-50" unless job.enabled? %>
  "
>
  <td class="pl-6 py-4">
    <% unless job.enabled? %>
      <div data-tooltip="<%= I18n.t("jobs.enabled.false") %>">
        <%= lucide_icon "circle-off", class: "h-4 w-4 text-gray-400" %>
      </div>
    <% end %>
  </td>

  <td class="pl-3 pr-6 py-4">
    <div class="font-medium text-gray-900 dark:text-gray-100">
      <%= job.name %>
    </div>

    <% if job.description.present? %>
      <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
        <%= job.description %>
      </div>
    <% end %>
  </td>

  <td class="px-6 py-4 text-gray-600 dark:text-gray-300">
    <%= job.source_repository.name %>
  </td>

  <td class="px-6 py-4 text-gray-600 dark:text-gray-300">
    <%= job.destination_repository.name %>
  </td>

  <td class="px-6 py-4 text-gray-600 dark:text-gray-300">
    <% if job.schedule.present? %>
      <span
        data-controller="cron-preview"
        data-cron-preview-placeholder-value=""
        data-cron-preview-invalid-value="<%= job.schedule %>"
      >
        <input
          type="hidden"
          data-cron-preview-target="input"
          value="<%= job.schedule %>"
        >

        <span class="text-xs" data-cron-preview-target="output">
          <%= job.schedule %>
        </span>
      </span>
    <% else %>
      —
    <% end %>
  </td>

  <td class="px-6 py-4">
    <div class="flex items-center justify-end gap-2">
      <%= link_to edit_job_path(job),
                  class: "btn-icon-outline btn-icon-md",
                  data: { tooltip: I18n.t("jobs.actions.edit"), turbo_frame: "_top" } do %>
        <%= lucide_icon "pencil", class: "h-4 w-4" %>
      <% end %>

      <%= button_to job_runs_path,
                    params: { job_id: job.id },
                    class: "btn-icon-outline btn-icon-md#{" cursor-not-allowed text-gray-400 dark:text-gray-600" unless job.enabled?}",
                    disabled: !job.enabled?,
                    form_class: "contents",
                    data: { tooltip: I18n.t("jobs.actions.run") } do %>
        <%= lucide_icon "play", class: "h-4 w-4" %>
      <% end %>

      <%= link_to job_path(job),
                  class: "btn-icon-outline btn-icon-md text-red-600 hover:text-red-700 dark:text-red-400",
                  data: {
                    tooltip: I18n.t("jobs.actions.delete"),
                    "turbo-method": :delete,
                    "turbo-confirm": I18n.t("jobs.actions.delete_confirm"),
                    "turbo-confirm-title": I18n.t("jobs.actions.delete_confirm_title"),
                    "turbo-confirm-destructive": true,
                  } do %>
        <%= lucide_icon "trash-2", class: "h-4 w-4" %>
      <% end %>
    </div>
  </td>
</tr>

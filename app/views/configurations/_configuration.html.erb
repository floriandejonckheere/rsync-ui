<%= turbo_frame_tag dom_id(configuration) do %>
  <% disabled = !configuration.all_dependencies_satisfied? %>

  <div
    id="config-<%= configuration.key.tr('.', '-') %>"
    class="py-4 border-b border-gray-100 dark:border-gray-700 last:border-b-0 <%= 'opacity-50' if disabled %>"
    data-controller="configuration"
    data-configuration-default-value="<%= configuration.default %>"
  >
    <div class="flex items-center justify-between">
      <div class="flex flex-col gap-1">
        <span class="text-lg font-semibold text-gray-700 dark:text-gray-200">
          <%= I18n.t("configurations.keys.#{configuration.key}.description") %>
        </span>

        <span class="font-mono text-sm text-gray-400 dark:text-gray-300">
          <%= configuration.key %>
        </span>

        <% if configuration.dependencies.any? %>
          <span class="text-xs text-gray-400 dark:text-gray-500">
            <%= I18n.t("configurations.index.depends_on") %>
            :
            <% configuration.dependencies.each_with_index do |dep, index| %>
              <a
                href="#config-<%= dep.tr('.', '-') %>"
                class="
                  font-mono text-primary-600 dark:text-primary-400
                  hover:underline
                "
                data-action="configuration#navigateToDependency"
              >
                <%= dep %>
              </a>

              <%= ", " unless index == configuration.dependencies.length - 1 %>
            <% end %>
          </span>
        <% end %>
      </div>

      <% if configuration.is_a?(Configuration::Boolean) %>
        <%= form_with(model: configuration, scope: :configuration, url: configuration_path(configuration), method: :patch) do |form| %>
          <%= form.hidden_field :value, value: "0", disabled: %>

          <%= form.checkbox :value,
                            checked: configuration.value,
                            value: "1",
                            name: "configuration[value]",
                            class: "input",
                            role: "switch",
                            disabled:,
                            onchange: "this.form.requestSubmit()" %>
        <% end %>
      <% else %>
        <div
          class="flex items-center gap-3"
          data-configuration-target="display"
        >
          <span class="font-mono text-sm text-gray-600 dark:text-gray-300">
            <%= configuration.value.presence || configuration.default %>
          </span>

          <% unless disabled %>
            <button
              type="button"
              class="btn-icon-outline btn-icon-md"
              data-action="configuration#toggle"
              title="<%= I18n.t("configurations.index.edit") %>"
            >
              <%= lucide_icon "pencil", class: "h-5 w-5" %>
            </button>
          <% end %>
        </div>
        <% unless disabled %>
          <div class="hidden" data-configuration-target="form">
            <%= form_with(model: configuration, scope: :configuration, url: configuration_path(configuration), method: :patch) do |form| %>
              <div class="flex gap-3 items-start">
                <button
                  type="button"
                  class="btn-icon-outline btn-icon-md"
                  data-action="configuration#revert"
                  title="<%= I18n.t("configurations.index.revert") %>"
                >
                  <%= lucide_icon "undo", class: "h-5 w-5" %>
                </button>

                <% case configuration %>
                <% when Configuration::String %>
                  <%= form.text_field :value,
                      value: configuration.value,
                      class: "input font-mono w-64",
                      placeholder: I18n.t("configurations.index.value_placeholder"),
                      data: { configuration_target: "value" } %>
                <% when Configuration::Integer, Configuration::Float %>
                  <%= form.number_field :value,
                                        value: configuration.value,
                                        class: "input font-mono w-64",
                                        placeholder: I18n.t("configurations.index.value_placeholder"),
                                        data: { configuration_target: "value" } %>
                <% else %>
                  <% raise ArgumentError, "Unsupported configuration type: #{configuration.class}" %>
                <% end %>

                <button
                  type="submit"
                  class="btn-icon-primary btn-icon-md"
                  title="<%= I18n.t("configurations.index.update") %>"
                >
                  <%= lucide_icon "check", class: "h-5 w-5" %>
                </button>

                <button
                  type="button"
                  class="btn-icon-outline btn-icon-md"
                  data-action="configuration#toggle"
                  title="<%= I18n.t("configurations.index.cancel") %>"
                >
                  <%= lucide_icon "x", class: "h-5 w-5" %>
                </button>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

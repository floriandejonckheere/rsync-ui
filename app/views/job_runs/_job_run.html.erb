<tr
  class="
    relative border-b border-gray-100 dark:border-gray-700 last:border-b-0
    hover:z-10 hover:bg-gray-50 dark:hover:bg-gray-700/50
  "
>
  <td class="pl-6 py-4">
    <% if job_run.trigger == "manual" %>
      <div data-tooltip="<%= I18n.t("job_runs.trigger.manual") %>">
        <%= lucide_icon "user", class: "h-4 w-4" %>
      </div>
    <% elsif job_run.trigger == "scheduled" %>
      <div data-tooltip="<%= I18n.t("job_runs.trigger.scheduled") %>">
        <%= lucide_icon "clock", class: "h-4 w-4" %>
      </div>
    <% end %>
  </td>

  <td class="pl-3 pr-6 py-4 font-mono text-gray-600 dark:text-gray-300">
    #<%= job_run.sequence %>
  </td>

  <td class="px-6 py-4">
    <div class="font-medium text-gray-900 dark:text-gray-100">
      <%= link_to job_run.job.name, edit_job_path(job_run.job), class: "hover:underline", data: { turbo_frame: "_top" } %>
    </div>
  </td>

  <td class="px-6 py-4 text-sm <%= job_run_status_classes(job_run.status) %>">
    <% if job_run.running? && job_run.progress.present? %>
      <%= I18n.t("job_runs.status.running_progress", progress: job_run.progress) %>
      <div
        role="progressbar"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="<%= job_run.progress %>"
        class="
          relative mt-1.5 h-1.5 w-full overflow-hidden rounded-full
          bg-blue-100 dark:bg-blue-950
        "
      >
        <div
          class="h-full w-full flex-1 bg-blue-600 dark:bg-blue-400 transition-all"
          style="transform: translateX(-<%= 100 - job_run.progress.to_i %>%)"
        ></div>
      </div>
    <% else %>
      <%= I18n.t("job_runs.status.#{job_run.status}") %>
    <% end %>
  </td>

  <td class="px-6 py-4 text-gray-600 dark:text-gray-300">
    <%= job_run.started_at ? relative_time_tag(job_run.started_at) : "—" %>
  </td>

  <td class="px-6 py-4 text-gray-600 dark:text-gray-300">
    <% if job_run.started_at.present? %>
      <%= distance_of_time_in_words(job_run.started_at, job_run.completed_at || Time.current) %>
    <% else %>
      —
    <% end %>
  </td>

  <td class="px-6 py-4 text-gray-600 dark:text-gray-300">
    <%= job_run.completed_at ? relative_time_tag(job_run.completed_at) : "—" %>
  </td>

  <td class="px-6 py-4">
    <div class="flex items-center justify-end gap-2">
      <% if job_run.deletable? && (job_run.output.attached? || job_run.errored?) %>
        <%= link_to job_run_path(job_run),
                    class: "btn-icon-outline btn-icon-md",
                    data: { tooltip: I18n.t("job_runs.actions.view_logs"), turbo_frame: "_top" } do %>
          <%= lucide_icon "eye", class: "h-4 w-4" %>
        <% end %>
        <% if job_run.output.attached? %>
          <%= link_to logs_job_run_path(job_run),
                      class: "btn-icon-outline btn-icon-md",
                      data: { tooltip: I18n.t("job_runs.actions.download_logs"), turbo: false } do %>
            <%= lucide_icon "download", class: "h-4 w-4" %>
          <% end %>
        <% end %>
      <% end %>

      <% if job_run.deletable? %>
        <%= link_to job_run_path(job_run),
                    class: "btn-icon-outline btn-icon-md text-red-600 hover:text-red-700 dark:text-red-400",
                    data: {
                      tooltip: I18n.t("job_runs.actions.delete"),
                      "turbo-method": :delete,
                      "turbo-confirm": I18n.t("job_runs.actions.delete_confirm"),
                      "turbo-confirm-title": I18n.t("job_runs.actions.delete_confirm_title"),
                      "turbo-confirm-destructive": true,
                    } do %>
          <%= lucide_icon "trash-2", class: "h-4 w-4" %>
        <% end %>
      <% elsif job_run.pending? || job_run.running? %>
        <%= link_to cancel_job_run_path(job_run),
                    class: "btn-icon-outline btn-icon-md",
                    data: {
                      tooltip: I18n.t("job_runs.actions.cancel"),
                      "turbo-method": :patch,
                      "turbo-confirm": I18n.t("job_runs.actions.cancel_confirm"),
                      "turbo-confirm-title": I18n.t("job_runs.actions.cancel_confirm_title"),
                    } do %>
          <%= lucide_icon "x", class: "h-4 w-4" %>
        <% end %>
      <% end %>
    </div>
  </td>
</tr>

<% content_for :back do %>
  <%= render "shared/menu/back", path: job_runs_path %>
<% end %>

<% content_for :title do %>
  <%= I18n.t("job_runs.show.title", sequence: @job_run.sequence) %>
<% end %>

<% content_for :subtitle do %>
  <%= I18n.t("job_runs.show.subtitle", job: @job_run.job.name) %>
<% end %>

<% if @job_run.error_class.present? || @job_run.error_messages.present? %>
  <div
    class="
      card p-0 mb-6 border-red-200 dark:border-red-900/50 bg-red-50/50
      dark:bg-red-950/10
    "
  >
    <div
      class="
        flex items-center gap-2 px-6 py-4 border-b border-red-100
        dark:border-red-900/50 text-red-700 dark:text-red-400 font-medium
      "
    >
      <%= lucide_icon "alert-circle", class: "h-4 w-4" %>
      <span><%= I18n.t("job_runs.show.error_details") %></span>
    </div>

    <div class="p-6">
      <% if @job_run.error_class.present? %>
        <div class="mb-4 last:mb-0">
          <div
            class="
              text-xs font-semibold text-red-600 dark:text-red-500 uppercase
              tracking-wider
            "
          >
            <%= I18n.t("job_runs.show.error_class") %>
          </div>

          <div class="mt-1 font-mono text-sm text-gray-900 dark:text-gray-100">
            <%= @job_run.error_class %>
          </div>
        </div>
      <% end %>

      <% if @job_run.error_messages.present? %>
        <div class="mb-4 last:mb-0">
          <div
            class="
              text-xs font-semibold text-red-600 dark:text-red-500 uppercase
              tracking-wider
            "
          >
            <%= I18n.t("job_runs.show.error_message") %>
          </div>

          <div
            class="
              mt-1 text-sm text-gray-900 dark:text-gray-100
              whitespace-pre-wrap
            "
          >
            <%= @job_run.error_messages %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @job_run.output.attached? %>
  <div class="card p-0">
    <div
      class="
        flex items-center justify-between px-6 py-4 border-b border-gray-100
        dark:border-gray-700
      "
    >
      <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
        <%= lucide_icon "file-text", class: "h-4 w-4" %>
        <span><%= I18n.t("job_runs.show.output_file") %></span>
      </div>

      <%= link_to logs_job_run_path(@job_run),
                  class: "btn-icon-outline btn-icon-md",
                  data: { tooltip: I18n.t("job_runs.actions.download_logs") } do %>
        <%= lucide_icon "download", class: "h-4 w-4" %>
      <% end %>
    </div>

    <pre
      class="
        p-6 text-xs font-mono text-gray-800 dark:text-gray-200
        whitespace-pre-wrap
      "
    ><%= @job_run.output.download %></pre>
  </div>
<% end %>

<%= render "hook_output", job_run: @job_run %>

<%# locals: (column:, label:) %>
<% showing_active = @active_sort_column == column.to_s
  param_active = @sort_column == column.to_s
  next_direction = if param_active
    @sort_direction == "asc" ? "desc" : nil
  else
    "asc"
  end

  sort_query = {}
  sort_query[:query] = @query if @query.present?
  sort_query[:filter] = @filters.to_h if @filters.present?
  sort_query.merge!(sort: column, direction: next_direction) if next_direction
  sort_href = [request.path, sort_query.to_query.presence].compact.join("?") %>

<th class="px-6 py-4 text-left font-medium text-gray-500 dark:text-gray-400">
  <%= link_to sort_href,
              data: { turbo_action: "replace" },
              class: "flex items-center gap-1 hover:text-gray-700 dark:hover:text-gray-200 whitespace-nowrap" do %>
    <%= label %>

    <% if showing_active && @active_sort_direction == "asc" %>
      <%= lucide_icon "chevron-up", class: "h-3.5 w-3.5 shrink-0" %>
    <% elsif showing_active && @active_sort_direction == "desc" %>
      <%= lucide_icon "chevron-down", class: "h-3.5 w-3.5 shrink-0" %>
    <% end %>
  <% end %>
</th>

<div
  class="
    fixed top-4 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4
    sm:max-w-lg
  "
>
  <% flash.each do |type, message| %>
    <% next if message.blank? %>

    <div
      role="alert"
      class="<%= alert_class_for(type) %> mb-4 shadow-lg relative"
      data-turbo-temporary
      data-controller="dismissible"
    >
      <%= lucide_icon icon_name_for(type), class: "w-4 h-4" %>

      <h2>
        <%= I18n.t("flash.types.#{type}", default: type.to_s.capitalize) %>
      </h2>

      <section><%= message %></section>

      <button
        type="button"
        class="absolute top-2 right-2 btn-icon-ghost p-1"
        aria-label="<%= I18n.t("shared.dismiss") %>"
        data-action="dismissible#dismiss"
      >
        <%= lucide_icon "x", class: "w-4 h-4" %>
      </button>
    </div>
  <% end %>
</div>

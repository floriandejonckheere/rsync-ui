<tr
  class="
    border-b border-gray-100 dark:border-gray-700 last:border-b-0
    hover:bg-gray-50 dark:hover:bg-gray-700/50
  "
>
  <td class="pl-6 py-4">
    <% if server.password.present? %>
      <div data-tooltip="<%= I18n.t("servers.table.password") %>">
        <%= lucide_icon "key-round", class: "h-4 w-4 text-blue-500" %>
      </div>
    <% elsif server.ssh_key.present? %>
      <div data-tooltip="<%= I18n.t("servers.table.ssh_key") %>">
        <%= lucide_icon "key", class: "h-4 w-4 text-green-500" %>
      </div>
    <% end %>
  </td>

  <td class="pl-3 pr-6 py-4">
    <div class="font-medium text-gray-900 dark:text-gray-100">
      <%= server.name %>
    </div>

    <% if server.description.present? %>
      <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
        <%= server.description %>
      </div>
    <% end %>
  </td>

  <td class="px-6 py-4 font-mono text-gray-600 dark:text-gray-300">
    <%= server.host %>:<%= server.port %>
  </td>

  <td class="px-6 py-4 font-mono text-gray-600 dark:text-gray-300">
    <%= server.username %>
  </td>

  <td class="px-6 py-4">
    <div class="flex items-center justify-end gap-2">
      <%= link_to edit_server_path(server),
                  class: "btn-icon-outline btn-icon-md",
                  data: { tooltip: I18n.t("servers.actions.edit") } do %>
        <%= lucide_icon "pencil", class: "h-4 w-4" %>
      <% end %>

      <%= link_to server_path(server),
                  class: "btn-icon-outline btn-icon-md text-red-600 hover:text-red-700 dark:text-red-400",
                  data: {
                    tooltip: I18n.t("servers.actions.delete"),
                    "turbo-method": :delete,
                    "turbo-confirm": I18n.t("servers.actions.delete_confirm"),
                    "turbo-confirm-title": I18n.t("servers.actions.delete_confirm_title"),
                    "turbo-confirm-destructive": true,
                  } do %>
        <%= lucide_icon "trash-2", class: "h-4 w-4" %>
      <% end %>
    </div>
  </td>
</tr>

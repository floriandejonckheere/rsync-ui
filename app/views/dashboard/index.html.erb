<% content_for :title do %>
  <%= I18n.t("dashboard.title") %>
<% end %>

<% content_for :subtitle do %>
  <%= I18n.t("dashboard.subtitle") %>
<% end %>

<% if Configuration.get("resource_usage") %>
  <div class="flex flex-col gap-4">
    <h2 class="text-lg font-semibold">
      <%= I18n.t("dashboard.server_health.title") %>
    </h2>

    <% if @servers.empty? %>
      <div class="flex flex-col items-center justify-center py-12 gap-4 text-gray-400">
        <%= lucide_icon "server", class: "h-12 w-12" %>

        <p class="text-lg">
          <%= I18n.t("dashboard.server_health.no_servers") %>
        </p>
      </div>
    <% else %>
      <div class="flex flex-wrap gap-4">
        <% @servers.each do |server| %>
          <%= render "dashboard/server_card", server: %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

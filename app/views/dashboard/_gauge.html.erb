<% text_color = case health
               when :ok then "text-green-500"
               when :warning then "text-yellow-400"
               when :critical then "text-red-500"
               else "text-gray-400 dark:text-gray-500"
               end %>

<div class="flex flex-col items-center gap-2 flex-1">
  <div
    class="relative w-20 h-20"
    data-controller="gauge"
    data-gauge-percent-value="<%= percent.present? ? percent.clamp(0, 100) : 0 %>"
    data-gauge-health-value="<%= health %>"
  >
    <canvas data-gauge-target="canvas"></canvas>

    <div class="absolute inset-0 flex items-center justify-center">
      <span class="text-sm font-bold <%= text_color %>">
        <% if percent.present? %>
          <%= number_to_percentage(percent, precision: 0) %>
        <% else %>
          &mdash;
        <% end %>
      </span>
    </div>
  </div>

  <div class="text-center">
    <span class="text-xs text-gray-500 dark:text-gray-400"><%= label %></span>

    <% if detail.present? %>
      <br>
      <span class="text-xs text-gray-400 dark:text-gray-500">
        <%= detail %>
      </span>
    <% end %>
  </div>
</div>
